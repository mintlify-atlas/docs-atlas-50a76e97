  "keyFeatures": [
    "Industrial-grade PKI with hardware-backed key storage",
    "Automated certificate lifecycle management",
    "EST (RFC 7030) enrollment protocol support",
    "Device identity management for IoT fleets",
    "Pluggable crypto engines (Software, AWS KMS, PKCS#11, Vault)",
    "Modular storage and event bus architecture",
    "Advanced filtering with JSONPath support",
    "Cloud and edge ready deployment options",
    "AWS IoT integration",
    "Certificate issuance profiles and policies"
  ],
  "publicApiSurface": [
    "POST /api/ca/v1/cas - Create Certificate Authority",
    "GET /api/ca/v1/certificates - List certificates",
    "POST /api/ca/v1/certificates/sign - Sign certificate request",
    "GET /api/devmanager/v1/devices - List devices",
    "POST /api/devmanager/v1/devices - Register device",
    "GET /api/devmanager/v1/device-groups - List device groups",
    "GET /api/dmsmanager/v1/dms - List DMS instances",
    "POST /.well-known/est/{dms-id}/simpleenroll - EST enrollment",
    "POST /.well-known/est/{dms-id}/simplereenroll - EST re-enrollment",
    "GET /api/kms/v1/engines - List crypto engines",
    "POST /api/kms/v1/keys - Create cryptographic key",
    "POST /api/kms/v1/keys/{id}/sign - Sign data with key",
    "GET /api/alerts/v1/alerts - List alerts",
    "GET /api/va/v1/validate - Validate certificate"
  ]
